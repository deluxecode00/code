{
  "rewrites": [
    {
      "source": "/buscar-json",
      "destination": "https://code-ylhz.onrender.com/buscar-json"
    },
    {
      "source": "/health",
      "destination": "https://code-ylhz.onrender.com/health"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://code-ylhz.onrender.com/auth/$1"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}